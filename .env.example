# FM Monitor - Variables d'environnement
# Copiez ce fichier vers .env et modifiez les valeurs

# Clé secrète pour les sessions Flask (OBLIGATOIRE en production)
# Générez une clé sécurisée avec: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-moi-par-une-cle-secrete-aleatoire-de-64-caracteres

# Environnement Flask (development ou production)
FLASK_ENV=production

# Optionnel: Hôte et port
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

