# FM Monitor - .gitignore

# Environnement Python
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Variables d'environnement (IMPORTANT - contient SECRET_KEY)
.env

# Configuration locale (contient mots de passe, emails)
config.json

# Certificats SSL (générés localement)
cert.pem
key.pem
*.crt
*.key
*.pem

# Logs
*.log
logs/

# Fichiers système
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Sauvegardes
backups/
backup_*/
*.backup
*.bak
*_backup_*

# Fichiers temporaires
tmp/
temp/
*.tmp

# Audio (fichiers de cache)
*.wav
*.mp3
audio_cache/

# Données utilisateur
user_data/
uploads/

# Tests
.pytest_cache/
.coverage
htmlcov/
.tox/

# Documentation build
docs/_build/
site/

# Fichiers spécifiques RTL-SDR
rtl_*.bin
